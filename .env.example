# ─── App ──────────────────────────────
APP_NAME=Herman AI
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-random-secret
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── Database ─────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=herman
MYSQL_PASSWORD=herman_pass
MYSQL_DATABASE=herman_ai

# ─── Redis ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Vector DB (Qdrant) ───────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=herman_embeddings

# ─── AI Providers ─────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Auth ─────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Storage ──────────────────────────
STORAGE_BACKEND=local
STORAGE_PATH=./uploads
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ─── Search ───────────────────────────
SERPER_API_KEY=
BRAVE_API_KEY=
TAVILY_API_KEY=

# ─── Celery ───────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── WebSocket ────────────────────────
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=10000

# ─── Rate Limiting ────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_PREMIUM=300/minute

# ─── Tools ────────────────────────────
TOOL_SSH_ENABLED=false
TOOL_DOCKER_ENABLED=false
TOOL_TIMEOUT_DEFAULT=30

# ─── Logging ──────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
